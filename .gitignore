# ── macOS ──
.DS_Store

# ── Gradle ──
.gradle/
build/
# wrapper 자체는 커밋 (프로젝트 빌드 재현용)
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ── IntelliJ IDEA ──
.idea/
*.iml
*.ipr
*.iws
out/

# ── Kotlin / Java 빌드 산출물 ──
*.class
*.log
bin/

# ── 시크릿 / 로컬 설정 (절대 커밋 금지) ──
# 실제 설정은 무시하고 application-example.yml 같은 예시 파일만 커밋할 것
.env
.env.*
*-local.yml
*-local.yaml
*-secret.yml
*-secret.yaml
application-local.*
src/main/resources/application-secret.*
